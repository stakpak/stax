{
  "name": "stax-workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/adapter/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "vite": "^7.3.1",
      "vitest": "^3.2.3",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format",
    "test": "turbo test",
    "test:run": "turbo test",
    "test:coverage": "turbo test:coverage",
    "ci:check": "pnpm lint && pnpm format:check && pnpm check-types && pnpm test && pnpm build"
  },
  "dependencies": {
    "@stax/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@stax/config": "workspace:*",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.28.1"
}
